# ============================================================
#  Variables d'environnement — COPIE CE FICHIER EN ".env"
#  Ne commite JAMAIS le fichier .env sur Git !
# ============================================================

# -------------------------------------------------------
# France Travail (principale source FR)
# → https://francetravail.io/inscription
# -------------------------------------------------------
FRANCE_TRAVAIL_CLIENT_ID=
FRANCE_TRAVAIL_CLIENT_SECRET=

# -------------------------------------------------------
# Adzuna (agrégateur FR, 250 req/jour gratuit)
# → https://developer.adzuna.com/signup
# -------------------------------------------------------
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# -------------------------------------------------------
# Jooble (~500 req/mois gratuit)
# → https://jooble.org/api/about
# -------------------------------------------------------
JOOBLE_API_KEY=

# -------------------------------------------------------
# Careerjet (gratuit, pas de clé requise)
# Optionnel : ID affilié
# -------------------------------------------------------
CAREERJET_AFFID=

# -------------------------------------------------------
# Brave Search (2000 req/mois gratuit)
# → https://brave.com/search/api/
# -------------------------------------------------------
BRAVE_API_KEY=

# -------------------------------------------------------
# Email (Gmail SMTP pour le rapport quotidien)
# Utilise un "mot de passe d'application" Gmail :
# → Compte Google → Sécurité → Mots de passe des applications
# -------------------------------------------------------
EMAIL_SENDER=ton.email@gmail.com
EMAIL_APP_PASSWORD=xxxx_xxxx_xxxx_xxxx

# -------------------------------------------------------
# IMAP (lecture des alertes email — source email_alerts)
#
# Pour Gmail :
#   1. Active IMAP dans Gmail :
#      Paramètres → Voir tous les paramètres →
#      Transfert et POP/IMAP → Activer IMAP
#   2. Crée un mot de passe d'application (même que EMAIL_APP_PASSWORD)
#   3. IMAP_HOST est auto-détecté pour Gmail — laisse vide
#
# Pour autres fournisseurs (Orange, Free, Outlook...) :
#   Renseigne IMAP_HOST manuellement.
# -------------------------------------------------------
IMAP_EMAIL=ton.email@gmail.com
IMAP_PASSWORD=mot_de_passe_application_gmail
IMAP_HOST=                   # Auto-détecté pour Gmail/Outlook/Yahoo/Orange/Free
IMAP_PORT=993                # IMAPS (SSL), ne pas changer

# -------------------------------------------------------
# Mode test (bot tourne sans envoyer d'email)
# -------------------------------------------------------
DRY_RUN=false
